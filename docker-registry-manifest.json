{
  "name": "CrowdSec Manager",
  "version": "2.0.0",
  "description": "Multi-proxy web management interface for CrowdSec security stack",
  "registry": "crowdsec-manager",
  "repository": "https://github.com/crowdsec-manager/crowdsec-manager",
  "documentation": "https://docs.crowdsec-manager.io",
  "license": "MIT",
  "maintainers": [
    {
      "name": "CrowdSec Manager Team",
      "email": "support@crowdsec-manager.io"
    }
  ],
  "images": {
    "base": {
      "name": "crowdsec-manager/crowdsec-manager",
      "tags": [
        "2.0.0",
        "latest"
      ],
      "description": "Base CrowdSec Manager image with multi-proxy support",
      "platforms": [
        "linux/amd64",
        "linux/arm64"
      ],
      "size_mb": 150,
      "dockerfile": "Dockerfile",
      "features": [
        "Multi-proxy architecture",
        "Plugin system",
        "Web UI",
        "REST API",
        "Health monitoring"
      ]
    },
    "proxy_variants": {
      "traefik": {
        "name": "crowdsec-manager/crowdsec-manager",
        "tags": [
          "2.0.0-traefik",
          "latest-traefik"
        ],
        "description": "CrowdSec Manager optimized for Traefik reverse proxy",
        "base_image": "crowdsec-manager/crowdsec-manager:2.0.0",
        "proxy_type": "traefik",
        "features": [
          "Whitelist management",
          "Captcha protection",
          "Log parsing",
          "Bouncer integration",
          "Health monitoring",
          "Pangolin/Gerbil add-ons"
        ],
        "supported_versions": [
          "traefik:v3.0+",
          "traefik:v2.10+"
        ]
      },
      "nginx": {
        "name": "crowdsec-manager/crowdsec-manager",
        "tags": [
          "2.0.0-nginx",
          "latest-nginx"
        ],
        "description": "CrowdSec Manager optimized for Nginx Proxy Manager",
        "base_image": "crowdsec-manager/crowdsec-manager:2.0.0",
        "proxy_type": "nginx",
        "features": [
          "Log parsing",
          "Bouncer integration",
          "Health monitoring"
        ],
        "supported_versions": [
          "jc21/nginx-proxy-manager:2.11+",
          "jc21/nginx-proxy-manager:2.10+"
        ]
      },
      "caddy": {
        "name": "crowdsec-manager/crowdsec-manager",
        "tags": [
          "2.0.0-caddy",
          "latest-caddy"
        ],
        "description": "CrowdSec Manager optimized for Caddy reverse proxy",
        "base_image": "crowdsec-manager/crowdsec-manager:2.0.0",
        "proxy_type": "caddy",
        "features": [
          "Bouncer integration",
          "Health monitoring",
          "Automatic HTTPS"
        ],
        "supported_versions": [
          "caddy:2.7+",
          "caddy:2.6+"
        ]
      },
      "haproxy": {
        "name": "crowdsec-manager/crowdsec-manager",
        "tags": [
          "2.0.0-haproxy",
          "latest-haproxy"
        ],
        "description": "CrowdSec Manager optimized for HAProxy load balancer",
        "base_image": "crowdsec-manager/crowdsec-manager:2.0.0",
        "proxy_type": "haproxy",
        "features": [
          "SPOA bouncer integration",
          "Health monitoring",
          "High performance"
        ],
        "supported_versions": [
          "haproxy:2.8+",
          "haproxy:2.6+"
        ]
      },
      "zoraxy": {
        "name": "crowdsec-manager/crowdsec-manager",
        "tags": [
          "2.0.0-zoraxy",
          "latest-zoraxy"
        ],
        "description": "CrowdSec Manager optimized for Zoraxy reverse proxy (experimental)",
        "base_image": "crowdsec-manager/crowdsec-manager:2.0.0",
        "proxy_type": "zoraxy",
        "experimental": true,
        "features": [
          "Basic health monitoring"
        ],
        "supported_versions": [
          "zoraxydocker/zoraxy:3.0+"
        ]
      },
      "standalone": {
        "name": "crowdsec-manager/crowdsec-manager",
        "tags": [
          "2.0.0-standalone",
          "latest-standalone"
        ],
        "description": "CrowdSec Manager in standalone mode (no reverse proxy)",
        "base_image": "crowdsec-manager/crowdsec-manager:2.0.0",
        "proxy_type": "standalone",
        "features": [
          "CrowdSec core management",
          "Health monitoring",
          "API access"
        ]
      }
    },
    "development": {
      "name": "crowdsec-manager/crowdsec-manager",
      "tags": [
        "2.0.0-dev",
        "dev"
      ],
      "description": "Development image with hot reload and development tools",
      "base_image": "golang:1.23-alpine",
      "dockerfile": "Dockerfile.dev",
      "features": [
        "Hot reload (Air)",
        "Development tools",
        "Source code mounting",
        "Debug capabilities"
      ],
      "ports": [
        "8080:8080",
        "3000:3000"
      ]
    }
  },
  "deployment_templates": {
    "single_proxy": [
      {
        "name": "Traefik",
        "file": "deployment-templates/docker-compose.traefik.yml",
        "description": "Full-featured Traefik deployment with all CrowdSec Manager capabilities",
        "complexity": "medium",
        "features": ["whitelist", "captcha", "logs", "bouncer", "health", "addons"]
      },
      {
        "name": "Nginx Proxy Manager",
        "file": "deployment-templates/docker-compose.nginx.yml",
        "description": "User-friendly NPM deployment with web UI management",
        "complexity": "low",
        "features": ["logs", "bouncer", "health"]
      },
      {
        "name": "Caddy",
        "file": "deployment-templates/docker-compose.caddy.yml",
        "description": "Simple Caddy deployment with automatic HTTPS",
        "complexity": "low",
        "features": ["bouncer", "health"]
      },
      {
        "name": "HAProxy",
        "file": "deployment-templates/docker-compose.haproxy.yml",
        "description": "High-performance HAProxy deployment with SPOA bouncer",
        "complexity": "high",
        "features": ["bouncer", "health"]
      },
      {
        "name": "Standalone",
        "file": "deployment-templates/docker-compose.standalone.yml",
        "description": "CrowdSec-only deployment without reverse proxy",
        "complexity": "minimal",
        "features": ["health"]
      }
    ],
    "profile_based": {
      "name": "Multi-proxy with profiles",
      "file": "docker-compose.yml",
      "description": "Single compose file with Docker profiles for all proxy types",
      "usage": [
        "docker-compose --profile traefik up -d",
        "docker-compose --profile nginx up -d",
        "docker-compose --profile caddy up -d",
        "docker-compose --profile haproxy up -d",
        "docker-compose --profile traefik --profile pangolin up -d"
      ]
    }
  },
  "environment_examples": {
    "traefik": "examples/traefik/.env",
    "nginx": "examples/nginx/.env",
    "caddy": "examples/caddy/.env",
    "haproxy": "examples/haproxy/.env",
    "zoraxy": "examples/zoraxy/.env",
    "standalone": "examples/standalone/.env",
    "traefik_with_addons": "examples/traefik-with-addons/.env"
  },
  "build_configuration": {
    "multi_arch": true,
    "platforms": [
      "linux/amd64",
      "linux/arm64"
    ],
    "build_args": {
      "GO_VERSION": "1.23",
      "NODE_VERSION": "20",
      "ALPINE_VERSION": "latest"
    },
    "build_script": "scripts/build-images.sh",
    "ci_cd": {
      "github_actions": ".github/workflows/build-images.yml",
      "auto_build": true,
      "auto_push": true,
      "registry_auth": "required"
    }
  },
  "usage_examples": {
    "quick_start": {
      "traefik": [
        "cp deployment-templates/docker-compose.traefik.yml docker-compose.yml",
        "cp examples/traefik/.env .env",
        "docker-compose up -d"
      ],
      "nginx": [
        "cp deployment-templates/docker-compose.nginx.yml docker-compose.yml",
        "cp examples/nginx/.env .env",
        "docker-compose up -d"
      ],
      "standalone": [
        "cp deployment-templates/docker-compose.standalone.yml docker-compose.yml",
        "cp examples/standalone/.env .env",
        "docker-compose up -d"
      ]
    },
    "development": [
      "docker run -d -p 8080:8080 -v $(pwd):/app crowdsec-manager/crowdsec-manager:dev"
    ],
    "production": [
      "docker run -d -p 8080:8080 -v ./data:/app/data crowdsec-manager/crowdsec-manager:2.0.0"
    ]
  },
  "health_checks": {
    "endpoint": "/health",
    "interval": "30s",
    "timeout": "3s",
    "retries": 3,
    "start_period": "5s"
  },
  "volumes": {
    "required": [
      "/var/run/docker.sock:/var/run/docker.sock",
      "./data:/app/data",
      "./config:/app/config",
      "./logs:/app/logs"
    ],
    "optional": [
      "./backups:/app/backups",
      "./docker-compose.yml:/app/docker-compose.yml"
    ]
  },
  "ports": {
    "crowdsec_manager": "8080:8080",
    "traefik_http": "80:80",
    "traefik_https": "443:443",
    "traefik_dashboard": "8081:8080",
    "npm_admin": "81:81",
    "caddy_admin": "2019:2019",
    "haproxy_stats": "8404:8404"
  },
  "compatibility": {
    "docker_version": "20.10+",
    "docker_compose_version": "2.0+",
    "crowdsec_version": "1.4+",
    "operating_systems": [
      "Ubuntu 20.04+",
      "Debian 11+",
      "CentOS 8+",
      "RHEL 8+",
      "Alpine Linux",
      "macOS (development)",
      "Windows (development)"
    ]
  },
  "security": {
    "base_image": "alpine:latest",
    "non_root_user": false,
    "security_scanning": true,
    "vulnerability_updates": "automatic",
    "secrets_management": "environment_variables"
  },
  "monitoring": {
    "metrics_endpoint": "/metrics",
    "log_format": "json",
    "log_levels": ["debug", "info", "warn", "error"],
    "health_endpoint": "/health",
    "ready_endpoint": "/ready"
  },
  "backup_restore": {
    "backup_endpoint": "/api/backup",
    "restore_endpoint": "/api/restore",
    "automatic_backup": true,
    "backup_retention": "configurable",
    "backup_formats": ["tar.gz", "zip"]
  },
  "migration": {
    "from_v1": {
      "automatic": true,
      "backward_compatible": true,
      "rollback_supported": true
    },
    "legacy_traefik": {
      "automatic_detection": true,
      "zero_downtime": true,
      "configuration_preservation": true
    }
  },
  "release_artifacts": {
    "docker_images": "Docker Hub registry",
    "source_code": "GitHub releases",
    "documentation": "GitHub Pages",
    "deployment_templates": "GitHub repository",
    "examples": "GitHub repository"
  }
}