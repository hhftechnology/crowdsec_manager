# ============================================================================
# CrowdSec Manager - Multi-Proxy Environment Configuration
# ============================================================================
# Copy this file to .env and configure for your deployment
# Usage: docker-compose --profile <proxy-type> up
# Example: docker-compose --profile traefik up

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

# Deployment Mode
COMPOSE_MODE=single                    # single|separate - Docker Compose deployment strategy
ENVIRONMENT=production                 # production|development
LOG_LEVEL=info                        # debug|info|warn|error

# Proxy Configuration
PROXY_TYPE=traefik                    # traefik|nginx|caddy|haproxy|zoraxy|standalone
PROXY_ENABLED=true                    # Enable proxy integration
PROXY_CONTAINER_NAME=                 # Auto-detected based on proxy type

# Network Configuration
NETWORK_NAME=crowdsec-network         # Docker network name
GID=1000                             # Group ID for file permissions

# ============================================================================
# CROWDSEC CONFIGURATION
# ============================================================================

# CrowdSec Core
CROWDSEC_COLLECTIONS=crowdsecurity/linux,crowdsecurity/traefik
ENROLL_INSTANCE_NAME=crowdsec-manager
ENROLL_TAGS=docker,multi-proxy

# Volume Names
CROWDSEC_DB_VOLUME=crowdsec-db
CROWDSEC_CONFIG_VOLUME=crowdsec-config

# ============================================================================
# CROWDSEC MANAGER CONFIGURATION
# ============================================================================

# Manager Service
MANAGER_PORT=8080                     # CrowdSec Manager web interface port
MANAGER_HOST=manager.localhost        # Hostname for manager interface

# Backup Configuration
RETENTION_DAYS=60                     # Backup retention period
INCLUDE_CROWDSEC=true                # Include CrowdSec data in backups

# ============================================================================
# TRAEFIK CONFIGURATION (Profile: traefik)
# ============================================================================

# Traefik Service
TRAEFIK_VERSION=latest               # Traefik Docker image version
TRAEFIK_CONTAINER_NAME=traefik       # Container name
TRAEFIK_HOST=traefik.localhost       # Traefik dashboard hostname

# Traefik Ports
TRAEFIK_HTTP_PORT=80                 # HTTP port
TRAEFIK_HTTPS_PORT=443               # HTTPS port
TRAEFIK_DASHBOARD_PORT=8081          # Dashboard port

# Traefik Configuration
TRAEFIK_API_INSECURE=true           # Enable insecure API (development only)
TRAEFIK_LOG_LEVEL=INFO              # Traefik log level

# Traefik Path Configuration (Container-Internal Paths)
# These paths are inside the Traefik container and can be customized
TRAEFIK_DYNAMIC_CONFIG=/etc/traefik/dynamic_config.yml
TRAEFIK_STATIC_CONFIG=/etc/traefik/traefik.yml
TRAEFIK_ACCESS_LOG=/var/log/traefik/access.log
TRAEFIK_ERROR_LOG=/var/log/traefik/traefik.log
TRAEFIK_ASSETS_DIR=/etc/traefik/assets
TRAEFIK_CAPTCHA_HTML=/etc/traefik/assets/captcha.html
TRAEFIK_RULES_DIR=/etc/traefik/rules
TRAEFIK_CONF_DIR=/etc/traefik/conf

# CrowdSec Path Configuration (Container-Internal Paths)
CROWDSEC_ACQUIS_FILE=/etc/crowdsec/acquis.yaml
CROWDSEC_ACQUIS_DIR=/etc/crowdsec/acquis.d
CROWDSEC_CONFIG_DIR=/etc/crowdsec
CROWDSEC_DATA_DIR=/var/lib/crowdsec/data
CROWDSEC_WHITELIST_FILE=/etc/crowdsec/parsers/s02-enrich/mywhitelists.yaml
CROWDSEC_NOTIFICATIONS_DIR=/etc/crowdsec/notifications
CROWDSEC_PROFILES_FILE=/etc/crowdsec/profiles.yaml

# Bouncer Status Thresholds
# These control when bouncers are considered "stale" or "connected"
BOUNCER_STALE_THRESHOLD_MINUTES=5     # Bouncer considered stale if not seen in this time
BOUNCER_CONNECTED_THRESHOLD_MINUTES=1 # Bouncer considered connected if seen within this time

# Manager Path Configuration (Container-Internal Paths)
MANAGER_CONFIG_DIR=/app/config
MANAGER_DATA_DIR=/app/data
MANAGER_BACKUP_DIR=/app/backups
MANAGER_LOG_DIR=/app/logs

# ============================================================================
# NGINX PROXY MANAGER CONFIGURATION (Profile: nginx)
# ============================================================================

# NPM Service
NPM_VERSION=latest                   # NPM Docker image version
NPM_CONTAINER_NAME=nginx-proxy-manager

# NPM Ports
NPM_HTTP_PORT=80                     # HTTP port
NPM_HTTPS_PORT=443                   # HTTPS port
NPM_ADMIN_PORT=81                    # Admin interface port

# NPM Configuration
NPM_DISABLE_IPV6=true               # Disable IPv6 support

# NPM Path Configuration (Container-Internal Paths)
NGINX_CONFIG_PATH=/data/nginx
NGINX_LOG_PATH=/data/logs

# ============================================================================
# CADDY CONFIGURATION (Profile: caddy)
# ============================================================================

# Caddy Service
CADDY_VERSION=latest                 # Caddy Docker image version
CADDY_CONTAINER_NAME=caddy

# Caddy Ports
CADDY_HTTP_PORT=80                   # HTTP port
CADDY_HTTPS_PORT=443                 # HTTPS port
CADDY_ADMIN_PORT=2019                # Admin API port

# Caddy Configuration
CADDY_ADMIN=0.0.0.0:2019            # Admin API bind address

# Caddy Path Configuration (Container-Internal Paths)
CADDY_CONFIG_PATH=/etc/caddy
CADDY_LOG_PATH=/var/log/caddy

# ============================================================================
# HAPROXY CONFIGURATION (Profile: haproxy)
# ============================================================================

# HAProxy Service
HAPROXY_VERSION=latest               # HAProxy Docker image version
HAPROXY_CONTAINER_NAME=haproxy

# HAProxy Ports
HAPROXY_HTTP_PORT=80                 # HTTP port
HAPROXY_HTTPS_PORT=443               # HTTPS port
HAPROXY_STATS_PORT=8404              # Statistics port

# HAProxy Path Configuration (Container-Internal Paths)
HAPROXY_CONFIG_PATH=/usr/local/etc/haproxy
HAPROXY_SOCKET_PATH=/var/run/haproxy.sock

# ============================================================================
# ZORAXY CONFIGURATION (Profile: zoraxy) - EXPERIMENTAL
# ============================================================================

# Zoraxy Service
ZORAXY_VERSION=latest                # Zoraxy Docker image version
ZORAXY_CONTAINER_NAME=zoraxy

# Zoraxy Ports
ZORAXY_HTTP_PORT=80                  # HTTP port
ZORAXY_HTTPS_PORT=443                # HTTPS port
ZORAXY_ADMIN_PORT=8000               # Admin interface port

# Zoraxy Path Configuration (Container-Internal Paths)
ZORAXY_CONFIG_PATH=/opt/zoraxy

# ============================================================================
# TRAEFIK ADD-ONS CONFIGURATION (Profiles: traefik + pangolin/gerbil)
# ============================================================================

# Pangolin Configuration
PANGOLIN_VERSION=latest              # Pangolin Docker image version
PANGOLIN_CONTAINER_NAME=pangolin
PANGOLIN_HOST=pangolin.localhost     # Pangolin hostname
PANGOLIN_DATA_VOLUME=pangolin-data   # Pangolin data volume

# Gerbil Configuration
GERBIL_VERSION=latest                # Gerbil Docker image version
GERBIL_CONTAINER_NAME=gerbil
GERBIL_HOST=gerbil.localhost         # Gerbil hostname

# Gerbil Ports
GERBIL_WIREGUARD_PORT=51820          # WireGuard port 1
GERBIL_WIREGUARD_PORT2=51830         # WireGuard port 2
GERBIL_WIREGUARD_PORT3=21820         # WireGuard port 3
GERBIL_API_PORT=51821                # Gerbil API port

# ============================================================================
# DEPLOYMENT EXAMPLES
# ============================================================================

# Example 1: Traefik with Pangolin and Gerbil
# PROXY_TYPE=traefik
# docker-compose --profile traefik --profile pangolin --profile gerbil up -d

# Example 2: Nginx Proxy Manager only
# PROXY_TYPE=nginx
# docker-compose --profile nginx up -d

# Example 3: Caddy only
# PROXY_TYPE=caddy
# docker-compose --profile caddy up -d

# Example 4: HAProxy only
# PROXY_TYPE=haproxy
# docker-compose --profile haproxy up -d

# Example 5: Standalone (CrowdSec only, no proxy)
# PROXY_TYPE=standalone
# docker-compose up -d

# Example 6: Zoraxy (Experimental)
# PROXY_TYPE=zoraxy
# docker-compose --profile zoraxy up -d