# CrowdSec Manager Configuration
# Copy to .env and adjust values

# Server port (default: 8080)
PORT=8080

# Proxy type: traefik, nginx, caddy, haproxy, zoraxy, standalone
# Leave empty for auto-detection from running containers
PROXY_TYPE=

# Container names (must match your docker-compose service names)
CROWDSEC_CONTAINER=crowdsec
PROXY_CONTAINER=traefik

# Data directory for SQLite database and backups
DATA_DIR=/app/data

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Development mode (enables CORS for localhost:5173)
DEV_MODE=false
